{
  "name": "design-system",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "storybook": "npm run storybook -w @ds/storybook",
    "build-storybook": "npm run build-storybook -w @ds/storybook",
    "clean": "npm run clean --workspaces --if-present",
    "verdaccio:up": "docker compose -f infra/verdaccio/docker-compose.yml up -d",
    "verdaccio:down": "docker compose -f infra/verdaccio/docker-compose.yml down",
    "verdaccio:add-user": "./scripts/add-user.sh",
    "publish:local": "./scripts/publish-local.sh"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
